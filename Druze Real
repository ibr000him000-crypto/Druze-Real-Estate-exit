                    <div class="footer">${t('receiptThank')}</div>
                </div>
            `;
            document.getElementById('receiptModal').classList.add('show');
        }

        function printReceipt() {
            const content = document.getElementById('receiptContent');
            const win = window.open('', '_blank');
            win.document.write(`
                <html><head><title>إيصال الدفع</title>
                <style>
                    body { font-family: 'Tajawal', sans-serif; direction: rtl; padding: 20px; background: white; }
                    .receipt { max-width: 400px; margin: 0 auto; border: 2px dashed #d4a373; padding: 24px; border-radius: 12px; }
                    .receipt .header { text-align: center; border-bottom: 2px solid #d4a373; padding-bottom: 12px; margin-bottom: 16px; }
                    .receipt .header h2 { color: #6d4c41; font-size: 22px; }
                    .receipt .header .sub { color: #666; font-size: 12px; }
                    .receipt .row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #eee; font-size: 14px; }
                    .receipt .row .label { color: #666; }
                    .receipt .row .value { font-weight: 700; color: #1a1a2e; }
                    .receipt .total { text-align: center; font-size: 20px; font-weight: 900; color: #d4a373; padding: 12px 0; margin-top: 8px; border-top: 2px solid #d4a373; }
                    .receipt .footer { text-align: center; font-size: 12px; color: #999; margin-top: 12px; }
                    @media print { .no-print { display: none; } }
                </style>
                </head><body>
                    ${content.innerHTML}
                    <div style="text-align:center;margin-top:16px;font-size:12px;color:#999;">© 2026 دروز للعقارية</div>
                </body></html>
            `);
            win.print();
        }

        // ============================================================
        // EDIT
        // ============================================================
        function openEditModal(id) {
            const rent = rents.find(r => r.id == id);
            if (!rent) return;
            editMode = true;
            editId = id;

            document.getElementById('modalTitle').innerHTML = t('modalTitleEdit');
            document.getElementById('buildingSelect').value = rent.building;
            document.getElementById('unitInput').value = rent.unit;
            document.getElementById('amountInput').value = rent.amount;
            document.getElementById('tenantInput').value = rent.tenant;
            document.getElementById('startDateInput').value = rent.startDate;
            document.getElementById('endDateInput').value = rent.endDate;

            document.getElementById('addModal').classList.add('show');
        }

        // ============================================================
        // DETAILS
        // ============================================================
        function showDetail(id) {
            const rent = rents.find(r => r.id == id);
            if (!rent) return;
            selectedRentId = id;

            const paidStatus = rent.paid ? t('paidStatus') : t('unpaidStatus');
            const startStr = new Date(rent.startDate).toLocaleDateString(
                currentLang === 'ar' ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' }
            );
            const endStr = new Date(rent.endDate).toLocaleDateString(
                currentLang === 'ar' ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' }
            );
            const daysLeft = getDaysLeft(rent.endDate);
            const daysText = getDaysLeftText(daysLeft);

            document.getElementById('detailTitle').innerHTML = `📋 <span class="gold">${rent.tenant}</span>`;
            document.getElementById('detailBody').innerHTML = `
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px;">
                    <div style="background:var(--bg);padding:10px 12px;border-radius:12px;grid-column:span 2;">
                        <div style="font-size:11px;color:var(--text-light);">${t('unitLabel')} + ${t('amountLabel')}</div>
                        <div style="font-size:16px;font-weight:800;color:var(--text);">شقه ${rent.unit} · رقم ${Number(rent.amount).toLocaleString()} ريال</div>
                    </div>
                    <div style="background:var(--bg);padding:10px 12px;border-radius:12px;">
                        <div style="font-size:11px;color:var(--text-light);">${t('buildingLabel')}</div>
                        <div style="font-size:15px;font-weight:800;color:var(--text);">${rent.building}</div>
                    </div>
                    <div style="background:var(--bg);padding:10px 12px;border-radius:12px;">
                        <div style="font-size:11px;color:var(--text-light);">${t('tenantLabel')}</div>
                        <div style="font-size:15px;font-weight:800;color:var(--text);">${rent.tenant}</div>
                    </div>
                    <div style="background:var(--bg);padding:10px 12px;border-radius:12px;">
                        <div style="font-size:11px;color:var(--text-light);">${t('startLabel')}</div>
                        <div style="font-size:15px;font-weight:800;color:var(--text);">${startStr}</div>
                    </div>
                    <div style="background:var(--bg);padding:10px 12px;border-radius:12px;">
                        <div style="font-size:11px;color:var(--text-light);">${t('endLabel')}</div>
                        <div style="font-size:15px;font-weight:800;color:var(--text);">${endStr}</div>
                    </div>
                    <div style="background:var(--bg);padding:10px 12px;border-radius:12px;">
                        <div style="font-size:11px;color:var(--text-light);">⏳ ${t('daysLeft')}</div>
                        <div style="font-size:15px;font-weight:800;color:${daysLeft > 15 ? 'var(--success)' : daysLeft > 0 ? 'var(--warning)' : 'var(--danger)'};">${daysText}</div>
                    </div>
                    <div style="background:var(--bg);padding:10px 12px;border-radius:12px;">
                        <div style="font-size:11px;color:var(--text-light);">${t('statusLabel')}</div>
                        <div style="font-size:15px;font-weight:800;color:${rent.paid ? '#2e7d32' : '#c62828'};">${paidStatus}</div>
                    </div>
                    ${rent.paidDate ? `
                    <div style="background:var(--bg);padding:10px 12px;border-radius:12px;grid-column:span 2;">
                        <div style="font-size:11px;color:var(--text-light);">${t('paidDateLabel')}</div>
                        <div style="font-size:15px;font-weight:800;color:var(--text);">${new Date(rent.paidDate).toLocaleDateString(currentLang === 'ar' ? 'ar-EG' : 'en-US')}</div>
                    </div>` : ''}
                </div>
            `;
            document.getElementById('detailModal').classList.add('show');
        }

        // ============================================================
        // DELETE
        // ============================================================
        document.getElementById('deleteRentBtn').addEventListener('click', function() {
            if (selectedRentId === null) return;
            if (!confirm(t('deleteConfirm'))) return;
            const index = rents.findIndex(r => r.id == selectedRentId);
            if (index !== -1) {
                rents.splice(index, 1);
                saveData();
                document.getElementById('detailModal').classList.remove('show');
                showToast(t('deleteSuccess'), 'success');
            }
        });

        document.getElementById('receiptFromDetailBtn').addEventListener('click', function() {
            if (selectedRentId !== null) {
                document.getElementById('detailModal').classList.remove('show');
                showReceipt(selectedRentId);
            }
        });

        function confirmDeleteAll() {
            if (rents.length === 0) {
                showToast(currentLang === 'ar' ? '⚠️ لا توجد بيانات للحذف' : '⚠️ No data to delete', 'error');
                return;
            }
            if (!confirm(t('deleteAllConfirm'))) return;
            rents = [];
            saveData();
            showToast(t('deleteAllSuccess'), 'success');
        }

        // ============================================================
        // EXPORT CSV
        // ============================================================
        function exportCSV() {
            if (rents.length === 0) {
                showToast(t('noDataExport'), 'error');
                return;
            }
            let csv = 'المخرج,شقه,رقم,المستأجر,تاريخ البدء,تاريخ الانتهاء,الحالة,تاريخ الدفع\n';
            rents.forEach(r => {
                const status = r.paid ? 'مدفوع' : 'غير مدفوع';
                const paidDate = r.paidDate ? new Date(r.paidDate).toLocaleDateString() : '';
                csv +=
                    `${r.building},${r.unit},${r.amount},${r.tenant},${r.startDate},${r.endDate},${status},${paidDate}\n`;
            });
            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = `DruzeRent_${new Date().toISOString().split('T')[0]}.csv`;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            showToast(t('exportSuccess'), 'success');
        }

        // ============================================================
        // FILTERS
        // ============================================================
        document.querySelectorAll('.filter-bar button').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.filter-bar button').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                currentFilter = this.dataset.filter;
                render();
            });
        });

        // ============================================================
        // MODALS CONTROL
        // ============================================================
        document.getElementById('addBtn').addEventListener('click', function() {
            editMode = false;
            editId = null;
            document.getElementById('modalTitle').innerHTML = t('modalTitleAdd');
            document.getElementById('unitInput').value = '';
            document.getElementById('amountInput').value = '';
            document.getElementById('tenantInput').value = '';
            document.getElementById('startDateInput').value = '';
            document.getElementById('endDateInput').value = '';
            document.getElementById('buildingSelect').value = 'مخرج 25';
            document.getElementById('addModal').classList.add('show');
        });

        document.getElementById('cancelModalBtn').addEventListener('click', function() {
            document.getElementById('addModal').classList.remove('show');
        });
        document.getElementById('addModal').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('show');
        });
        document.getElementById('detailModal').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('show');
        });
        document.getElementById('closeDetailBtn').addEventListener('click', function() {
            document.getElementById('detailModal').classList.remove('show');
        });
        document.getElementById('closeReceiptBtn').addEventListener('click', function() {
            document.getElementById('receiptModal').classList.remove('show');
        });
        document.getElementById('receiptModal').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('show');
        });

        // ============================================================
        // SAVE RENT
        // ============================================================
        document.getElementById('saveRentBtn').addEventListener('click', function() {
            const building = document.getElementById('buildingSelect').value;
            const unit = document.getElementById('unitInput').value.trim();
            const amount = document.getElementById('amountInput').value.trim();
            const tenant = document.getElementById('tenantInput').value.trim();
            const startDate = document.getElementById('startDateInput').value;
            const endDate = document.getElementById('endDateInput').value;

            if (!unit || !amount || !tenant || !startDate || !endDate) {
                showToast(t('fillError'), 'error');
                return;
            }
            if (isNaN(unit) || isNaN(amount) || Number(unit) < 1 || Number(amount) < 1) {
                showToast(t('rentError'), 'error');
                return;
            }
            if (new Date(startDate) > new Date(endDate)) {
                showToast(t('dateError'), 'error');
                return;
            }

            if (!editMode) {
                if (rents.some(r => r.building === building && r.unit == unit)) {
                    showToast(t('duplicateError') + unit + t('duplicateError2') + building, 'error');
                    return;
                }
                const newRent = {
                    id: Date.now(),
                    building,
                    unit: Number(unit),
                    amount: Number(amount),
                    tenant,
                    startDate,
                    endDate,
                    paid: false,
                    paidDate: null
                };
                rents.push(newRent);
                saveData();
                document.getElementById('addModal').classList.remove('show');
                showToast(`✅ ${tenant} ${currentLang === 'ar' ? 'تم حفظ الإيجار' : 'rent saved'}`, 'success');
            } else {
                const index = rents.findIndex(r => r.id == editId);
                if (index !== -1) {
                    rents[index] = { ...rents[index], building, unit: Number(unit), amount: Number(amount), tenant,
                        startDate, endDate };
                    saveData();
                    document.getElementById('addModal').classList.remove('show');
                    showToast(`✅ ${tenant} ${currentLang === 'ar' ? 'تم التعديل' : 'updated'}`, 'success');
                }
            }
        });

        // ============================================================
        // TOAST
        // ============================================================
        function showToast(msg, type = '') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.textContent = msg;
            container.innerHTML = '';
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.5s';
                setTimeout(() => toast.remove(), 500);
            }, 3000);
        }

        // ============================================================
        // INIT
        // ============================================================
        loadData();
        updateUI();

        // Auto-check notifications every minute
        setInterval(checkNotifications, 60000);

        // Close modals with Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                document.querySelectorAll('.modal.show').forEach(m => m.classList.remove('show'));
            }
        });

        // Fix for mobile touch
        document.addEventListener('touchstart', function() {}, { passive: true });
    </script>

</body>
</html>
