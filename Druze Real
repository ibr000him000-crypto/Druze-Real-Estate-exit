        // ============================================================
        // DATA
        // ============================================================
        function loadData() {
            const saved = localStorage.getItem('druzeMasterData');
            if (saved) {
                try { rents = JSON.parse(saved); } catch (e) { rents = []; }
            } else { rents = []; }
            render();
            checkNotifications();
            document.getElementById('rentBadge').textContent = rents.length;
            updateBuildings();
            updateReports();
            updateReceipts();
        }

        function saveData() {
            localStorage.setItem('druzeMasterData', JSON.stringify(rents));
            render();
            checkNotifications();
            document.getElementById('rentBadge').textContent = rents.length;
            updateBuildings();
            updateReports();
            updateReceipts();
        }

        // ============================================================
        // NOTIFICATIONS
        // ============================================================
        function checkNotifications() {
            const banner = document.getElementById('notifBanner');
            const notifText = document.getElementById('notifText');
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            const upcoming = rents.filter(r => {
                if (r.paid) return false;
                const end = new Date(r.endDate);
                end.setHours(0, 0, 0, 0);
                const diff = (end - today) / (1000 * 60 * 60 * 24);
                return diff >= 0 && diff <= 15;
            });
            if (upcoming.length > 0) {
                banner.style.display = 'block';
                notifText.textContent = currentLang === 'ar' ?
                    `🔔 لديك ${upcoming.length} إيجار(ات) مستحقة خلال 15 يومًا` :
                    `🔔 You have ${upcoming.length} rent(s) due within 15 days`;
            } else {
                banner.style.display = 'none';
            }
        }

        // ============================================================
        // CALCULATE DAYS LEFT
        // ============================================================
        function getDaysLeft(endDate) {
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            const end = new Date(endDate);
            end.setHours(0, 0, 0, 0);
            return Math.ceil((end - today) / (1000 * 60 * 60 * 24));
        }

        function getDaysLeftText(days) {
            if (days > 0) {
                return `${days} ${t('daysLeft')}`;
            } else if (days === 0) {
                return currentLang === 'ar' ? 'اليوم' : 'Today';
            } else {
                return `${Math.abs(days)} ${t('daysLate')}`;
            }
        }

        function getDaysLeftClass(days) {
            if (days > 15) return 'good';
            if (days > 0 && days <= 15) return 'warning';
            return 'danger';
        }

