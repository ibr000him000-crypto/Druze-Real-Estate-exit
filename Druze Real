        // ============================================================
        // MARK PAID
        // ============================================================
        function markPaid(id) {
            const rent = rents.find(r => r.id == id);
            if (!rent) return;
            if (confirm((currentLang === 'ar' ? 'هل تم استلام المبلغ من ' : 'Have you received the payment from ') + rent
                    .tenant + '?')) {
                rent.paid = true;
                rent.paidDate = new Date().toISOString();
                saveData();
                showToast((currentLang === 'ar' ? '✅ تم تسجيل الدفع لـ ' : '✅ Payment recorded for ') + rent.tenant,
                'success');
                showReceipt(id);
            }
        }

