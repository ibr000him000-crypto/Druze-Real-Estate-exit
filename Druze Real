<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>دروز للعقارية - Druze Real Estate</title>
    <style>
        /* ============================================================
           MASTER STYLES - کامل اور پیشہ ورانہ ڈیزائن
           ============================================================ */
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;700;800;900&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Tajawal', 'Segoe UI', sans-serif;
        }

        :root {
            --bg: #f5efe8;
            --bg-dark: #e8ddd0;
            --surface: rgba(255, 248, 240, 0.88);
            --surface-solid: #fff8f0;
            --glass-border: rgba(139, 115, 85, 0.12);
            --primary: #6d4c41;
            --primary-dark: #4e342e;
            --primary-light: #8d6e63;
            --gold: #d4a373;
            --gold-dark: #b8834a;
            --gold-light: #f0dcc8;
            --text: #3e2723;
            --text-light: #8d6e63;
            --text-white: #f5efe8;
            --shadow: 0 8px 40px rgba(0, 0, 0, 0.06);
            --shadow-hover: 0 12px 48px rgba(0, 0, 0, 0.1);
            --radius: 20px;
            --radius-sm: 14px;
            --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --success: #2e7d32;
            --success-bg: rgba(46, 125, 50, 0.1);
            --danger: #c62828;
            --danger-bg: rgba(198, 40, 40, 0.1);
            --warning: #f57f17;
            --warning-bg: rgba(245, 127, 23, 0.1);
            --sidebar-width: 220px;
            --header-height: 70px;
        }

        [data-theme="dark"] {
            --bg: #1a120e;
            --bg-dark: #2a1f18;
            --surface: rgba(40, 30, 24, 0.88);
            --surface-solid: #2a1f18;
            --glass-border: rgba(212, 163, 115, 0.08);
            --primary: #d4a373;
            --primary-dark: #b8834a;
            --primary-light: #c9a87c;
            --gold: #d4a373;
            --gold-dark: #b8834a;
            --gold-light: #3d2e24;
            --text: #f0e6d8;
            --text-light: #b8a08a;
            --text-white: #f5efe8;
            --shadow: 0 8px 40px rgba(0, 0, 0, 0.3);
            --shadow-hover: 0 12px 48px rgba(0, 0, 0, 0.4);
            --success-bg: rgba(46, 125, 50, 0.2);
            --danger-bg: rgba(198, 40, 40, 0.2);
            --warning-bg: rgba(245, 127, 23, 0.2);
        }

        body {
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            transition: var(--transition);
            direction: rtl;
        }

        /* ============================================================
           SIDEBAR - شیشے کا اثر
           ============================================================ */
        .sidebar {
            position: fixed;
            top: 0;
            right: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--surface);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-left: 1px solid var(--glass-border);
            box-shadow: var(--shadow);
            padding: 20px 14px;
            transition: var(--transition);
            z-index: 100;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .sidebar .brand {
            text-align: center;
            padding-bottom: 16px;
            border-bottom: 2px solid var(--gold);
            margin-bottom: 16px;
            flex-shrink: 0;
        }

        .sidebar .brand h1 {
            font-size: 20px;
            font-weight: 900;
            color: var(--gold);
            line-height: 1.3;
        }

        .sidebar .brand .sub {
            font-size: 11px;
            color: var(--text-light);
            font-weight: 300;
        }

        .sidebar .menu {
            list-style: none;
            flex: 1;
        }

        .sidebar .menu li {
            margin-bottom: 2px;
        }

        .sidebar .menu li a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: var(--radius-sm);
            color: var(--text-light);
            text-decoration: none;
            font-weight: 700;
            font-size: 13px;
            transition: var(--transition);
            cursor: pointer;
            position: relative;
        }

        .sidebar .menu li a:hover {
            background: var(--gold);
            color: var(--text-white);
            transform: translateX(-4px);
        }

        .sidebar .menu li a.active {
            background: var(--gold);
            color: var(--text-white);
            box-shadow: 0 4px 20px rgba(212, 163, 115, 0.2);
        }

        .sidebar .menu li a .icon {
            font-size: 18px;
            width: 26px;
            text-align: center;
            flex-shrink: 0;
        }

        .sidebar .menu li a .badge {
            margin-right: auto;
            background: var(--danger);
            color: white;
            padding: 1px 10px;
            border-radius: 50px;
            font-size: 10px;
        }

        .sidebar .user-info {
            padding-top: 16px;
            border-top: 1px solid var(--glass-border);
            text-align: center;
            flex-shrink: 0;
        }

        .sidebar .user-info .name {
            font-weight: 800;
            font-size: 14px;
            color: var(--text);
        }

        .sidebar .user-info .role {
            font-size: 11px;
            color: var(--text-light);
        }

        /* ============================================================
           MAIN CONTENT
           ============================================================ */
        .main-content {
            margin-right: var(--sidebar-width);
            padding: 14px 18px;
            min-height: 100vh;
            transition: var(--transition);
        }

        /* ============================================================
           TOPBAR
           ============================================================ */
        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            padding: 12px 20px;
            background: var(--surface);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            margin-bottom: 16px;
            gap: 10px;
            transition: var(--transition);
        }

        .topbar .page-title {
            font-size: 22px;
            font-weight: 800;
        }

        .topbar .page-title .gold {
            color: var(--gold);
        }

        .topbar-actions {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            align-items: center;
        }

        .topbar-actions button {
            background: var(--bg);
            border: none;
            padding: 6px 14px;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 700;
            font-size: 13px;
            color: var(--text);
            transition: var(--transition);
            font-family: 'Tajawal', sans-serif;
            border: 1px solid transparent;
        }

        .topbar-actions button:hover {
            background: var(--gold);
            color: var(--text-white);
            transform: translateY(-2px);
        }

        .topbar-actions button.active {
            background: var(--gold);
            color: var(--text-white);
        }

        .theme-toggle {
            font-size: 18px;
            padding: 4px 10px !important;
        }

        /* ============================================================
           PAGE SECTIONS
           ============================================================ */
        .page-section {
            display: none;
            animation: fadeSlide 0.4s ease;
        }

        .page-section.active {
            display: block;
        }

        @keyframes fadeSlide {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .page-header {
            font-size: 20px;
            font-weight: 800;
            color: var(--gold);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* ============================================================
           STATS CARDS
           ============================================================ */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 12px;
            margin-bottom: 16px;
        }

        .stat-card {
            background: var(--surface);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
            padding: 16px 12px;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            text-align: center;
            transition: var(--transition);
            border-bottom: 4px solid var(--gold);
            cursor: default;
        }

        .stat-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-hover);
        }

        .stat-card .num {
            font-size: 28px;
            font-weight: 900;
            color: var(--gold);
        }

        .stat-card .label {
            font-size: 12px;
            color: var(--text-light);
            margin-top: 2px;
        }

        .stat-card.green {
            border-bottom-color: var(--success);
        }
        .stat-card.green .num {
            color: var(--success);
        }
        .stat-card.red {
            border-bottom-color: var(--danger);
        }
        .stat-card.red .num {
            color: var(--danger);
        }
        .stat-card.warning {
            border-bottom-color: var(--warning);
        }
        .stat-card.warning .num {
            color: var(--warning);
        }

        /* ============================================================
           NOTIFICATION BANNER
           ============================================================ */
        .notification-banner {
            background: var(--surface);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
            padding: 12px 18px;
            border-radius: var(--radius);
            margin-bottom: 14px;
            border-right: 5px solid var(--warning);
            color: var(--text);
            font-weight: 700;
            box-shadow: var(--shadow);
            display: none;
            transition: var(--transition);
        }

        /* ============================================================
           SEARCH BAR
           ============================================================ */
        .search-bar {
            background: var(--surface);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius);
            padding: 10px 16px;
            box-shadow: var(--shadow);
            margin-bottom: 14px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
            transition: var(--transition);
        }

        .search-bar input {
            flex: 1;
            padding: 10px 16px;
            border: 2px solid var(--bg);
            border-radius: 50px;
            font-size: 14px;
            background: var(--bg);
            color: var(--text);
            font-family: 'Tajawal', sans-serif;
            transition: var(--transition);
            min-width: 130px;
        }

        .search-bar input:focus {
            outline: none;
            border-color: var(--gold);
            background: var(--surface-solid);
        }

        .search-bar input::placeholder {
            color: var(--text-light);
        }

        .search-bar button {
            background: var(--gold);
            border: none;
            padding: 10px 20px;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 800;
            font-size: 13px;
            color: var(--text-white);
            transition: var(--transition);
            font-family: 'Tajawal', sans-serif;
            white-space: nowrap;
        }

        .search-bar button:hover {
            transform: scale(1.03);
            box-shadow: 0 4px 20px rgba(212, 163, 115, 0.3);
        }

        .search-bar .clear-btn {
            background: var(--bg);
            color: var(--text-light);
            padding: 10px 14px;
        }

        .search-bar .clear-btn:hover {
            background: var(--text-light);
            color: white;
            box-shadow: none;
        }

        /* ============================================================
           ACTION BAR
           ============================================================ */
        .action-bar {
            display: flex;
            gap: 8px;
            margin-bottom: 14px;
            flex-wrap: wrap;
        }

        .action-bar .btn {
            padding: 10px 18px;
            border: none;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 800;
            cursor: pointer;
            transition: var(--transition);
            font-family: 'Tajawal', sans-serif;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .btn-primary {
            background: var(--gold);
            color: var(--text-white);
            box-shadow: 0 4px 20px rgba(212, 163, 115, 0.2);
        }

        .btn-primary:hover {
            transform: scale(1.03);
            box-shadow: 0 6px 28px rgba(212, 163, 115, 0.3);
        }

        .btn-outline {
            background: transparent;
            border: 2px solid var(--gold);
            color: var(--gold);
        }

        .btn-outline:hover {
            background: var(--gold);
            color: var(--text-white);
        }

        .btn-danger {
            background: var(--danger);
            color: white;
        }

        .btn-danger:hover {
            background: #b71c1c;
            transform: scale(1.03);
        }

        /* ============================================================
           FILTER BAR
           ============================================================ */
        .filter-bar {
            display: flex;
            gap: 6px;
            margin-bottom: 14px;
            flex-wrap: wrap;
        }

        .filter-bar button {
            padding: 6px 16px;
            border: 2px solid var(--surface);
            border-radius: 50px;
            background: var(--surface);
            backdrop-filter: blur(10px);
            color: var(--text-light);
            cursor: pointer;
            font-weight: 700;
            font-size: 11px;
            transition: var(--transition);
            font-family: 'Tajawal', sans-serif;
            box-shadow: var(--shadow);
        }

        .filter-bar button.active {
            background: var(--gold);
            color: var(--text-white);
            border-color: var(--gold);
            box-shadow: 0 4px 20px rgba(212, 163, 115, 0.15);
        }

        .filter-bar button:hover {
            transform: translateY(-2px);
        }

        /* ============================================================
           RENT LIST
           ============================================================ */
        .rent-list {
            background: var(--surface);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius);
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: var(--transition);
        }

        .rent-item {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr auto auto;
            padding: 14px 18px;
            border-bottom: 1px solid var(--glass-border);
            align-items: center;
            gap: 8px;
            transition: var(--transition);
            cursor: pointer;
        }

        .rent-item:hover {
            background: rgba(212, 163, 115, 0.04);
        }

        .rent-item:last-child {
            border-bottom: none;
        }

        .rent-item .info .name {
            font-weight: 800;
            color: var(--text);
            font-size: 15px;
        }

        .rent-item .info .unit {
            font-size: 12px;
            color: var(--gold-dark);
            font-weight: 700;
        }

        .rent-item .info .small {
            font-size: 11px;
            color: var(--text-light);
        }

        .rent-item .amount {
            font-weight: 800;
            color: var(--gold-dark);
            font-size: 15px;
        }

        .rent-item .days-left {
            font-size: 12px;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 50px;
            text-align: center;
            white-space: nowrap;
        }

        .days-left.good {
            background: var(--success-bg);
            color: var(--success);
        }
        .days-left.warning {
            background: var(--warning-bg);
            color: var(--warning);
        }
        .days-left.danger {
            background: var(--danger-bg);
            color: var(--danger);
        }

        .rent-item .status {
            font-size: 10px;
            padding: 3px 12px;
            border-radius: 50px;
            text-align: center;
            font-weight: 700;
            white-space: nowrap;
        }

        .status.paid {
            background: var(--success-bg);
            color: var(--success);
        }
        .status.unpaid {
            background: var(--danger-bg);
            color: var(--danger);
        }
        .status.warning {
            background: var(--warning-bg);
            color: var(--warning);
        }

        .rent-item .actions {
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
        }

        .rent-item .actions button {
            border: none;
            padding: 5px 12px;
            border-radius: 50px;
            cursor: pointer;
            font-size: 10px;
            font-weight: 800;
            font-family: 'Tajawal', sans-serif;
            transition: var(--transition);
            white-space: nowrap;
        }

        .rent-item .actions .pay-btn {
            background: var(--success);
            color: white;
        }
        .rent-item .actions .pay-btn:hover {
            background: #1b5e20;
            transform: scale(1.05);
        }

        .rent-item .actions .edit-btn {
            background: var(--warning);
            color: white;
        }
        .rent-item .actions .edit-btn:hover {
            background: #e65100;
            transform: scale(1.05);
        }

        .rent-item .actions .receipt-btn {
            background: var(--primary);
            color: white;
        }
        .rent-item .actions .receipt-btn:hover {
            background: var(--primary-dark);
            transform: scale(1.05);
        }

        .rent-item .notif-badge {
            background: var(--danger);
            color: white;
            border-radius: 50px;
            padding: 1px 10px;
            font-size: 9px;
            font-weight: 800;
            margin-right: 4px;
        }

        .rent-item .plate-badge {
            background: var(--gold);
            color: var(--text-white);
            border-radius: 50px;
            padding: 1px 8px;
            font-size: 9px;
            font-weight: 800;
        }

        /* ============================================================
           EMPTY STATE
           ============================================================ */
        .empty-state {
            text-align: center;
            padding: 50px 16px;
            color: var(--text-light);
        }

        .empty-state .icon {
            font-size: 50px;
            margin-bottom: 12px;
        }

        .empty-state h3 {
            font-weight: 700;
            color: var(--text);
        }

        /* ============================================================
           MODALS
           ============================================================ */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 999;
            justify-content: center;
            align-items: center;
            padding: 16px;
        }

        .modal.show {
            display: flex;
        }

        .modal-content {
            background: var(--surface-solid);
            padding: 28px 24px;
            border-radius: 24px;
            width: 100%;
            max-width: 520px;
            max-height: 92vh;
            overflow-y: auto;
            box-shadow: 0 24px 64px rgba(0, 0, 0, 0.15);
            animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            border: 1px solid var(--glass-border);
        }

        @keyframes slideUp {
            from {
                transform: translateY(40px) scale(0.96);
                opacity: 0;
            }
            to {
                transform: translateY(0) scale(1);
                opacity: 1;
            }
        }

        .modal-content h2 {
            color: var(--text);
            margin-bottom: 18px;
            text-align: center;
            font-weight: 900;
            font-size: 22px;
        }

        .modal-content h2 .gold {
            color: var(--gold);
        }

        .modal-content label {
            display: block;
            font-weight: 700;
            margin-top: 12px;
            font-size: 13px;
            color: var(--text-light);
        }

        .modal-content input,
        .modal-content select {
            width: 100%;
            padding: 10px 14px;
            border: 2px solid var(--bg);
            border-radius: var(--radius-sm);
            font-size: 14px;
            margin-top: 3px;
            transition: var(--transition);
            background: var(--bg);
            color: var(--text);
            font-family: 'Tajawal', sans-serif;
        }

        .modal-content input:focus,
        .modal-content select:focus {
            border-color: var(--gold);
            outline: none;
            background: var(--surface-solid);
        }

        .modal-actions {
            display: flex;
            gap: 10px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .modal-actions button {
            flex: 1;
            padding: 10px 16px;
            border: none;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 800;
            cursor: pointer;
            transition: var(--transition);
            font-family: 'Tajawal', sans-serif;
            min-width: 70px;
        }

        .modal-actions .save-btn {
            background: var(--gold);
            color: var(--text-white);
            box-shadow: 0 4px 20px rgba(212, 163, 115, 0.2);
        }

        .modal-actions .save-btn:hover {
            transform: scale(1.03);
        }

        .modal-actions .cancel-btn {
            background: var(--bg);
            color: var(--text-light);
        }

        .modal-actions .cancel-btn:hover {
            background: var(--text-light);
            color: var(--text-white);
        }

        .modal-actions .danger-btn {
            background: var(--danger);
            color: white;
        }

        .modal-actions .danger-btn:hover {
            background: #b71c1c;
        }

        /* ============================================================
           RECEIPT
           ============================================================ */
        .receipt {
            background: white;
            padding: 24px 20px;
            border-radius: 16px;
            max-width: 400px;
            margin: 0 auto;
            border: 2px dashed var(--gold);
            color: #1a1a2e;
        }

        .receipt .header {
            text-align: center;
            border-bottom: 2px solid var(--gold);
            padding-bottom: 10px;
            margin-bottom: 12px;
        }

        .receipt .header h2 {
            color: var(--primary);
            font-size: 20px;
            font-weight: 900;
        }

        .receipt .header .sub {
            color: #666;
            font-size: 11px;
        }

        .receipt .row {
            display: flex;
            justify-content: space-between;
            padding: 5px 0;
            border-bottom: 1px solid #eee;
            font-size: 13px;
        }

        .receipt .row .label {
            color: #666;
            font-weight: 400;
        }

        .receipt .row .value {
            font-weight: 700;
            color: #1a1a2e;
        }

        .receipt .total {
            text-align: center;
            font-size: 18px;
            font-weight: 900;
            color: var(--gold);
            padding: 10px 0;
            margin-top: 6px;
            border-top: 2px solid var(--gold);
        }

        .receipt .footer {
            text-align: center;
            font-size: 11px;
            color: #999;
            margin-top: 10px;
        }

        .receipt-actions {
            display: flex;
            gap: 8px;
            margin-top: 14px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .receipt-actions button {
            padding: 8px 20px;
            border: none;
            border-radius: 50px;
            font-weight: 800;
            cursor: pointer;
            font-family: 'Tajawal', sans-serif;
            transition: var(--transition);
        }

        .receipt-actions .print-btn {
            background: var(--primary);
            color: white;
        }

        .receipt-actions .print-btn:hover {
            background: var(--primary-dark);
        }

        .receipt-actions .close-btn {
            background: var(--bg);
            color: var(--text-light);
        }

        .receipt-actions .close-btn:hover {
            background: var(--text-light);
            color: white;
        }

        /* ============================================================
           TOAST
           ============================================================ */
        .toast-container {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            width: 90%;
            max-width: 400px;
        }

        .toast {
            background: var(--surface-solid);
            color: var(--text);
            padding: 12px 20px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 14px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
            text-align: center;
            animation: slideUp 0.3s ease;
            border-right: 5px solid var(--gold);
            font-family: 'Tajawal', sans-serif;
        }

        .toast.success {
            border-right-color: var(--success);
        }
        .toast.error {
            border-right-color: var(--danger);
        }

        /* ============================================================
           FOOTER
           ============================================================ */
        .footer {
            text-align: center;
            margin-top: 20px;
            padding: 12px;
            font-size: 11px;
            color: var(--text-light);
            font-weight: 300;
        }

        /* ============================================================
           SCROLLBAR
           ============================================================ */
        ::-webkit-scrollbar {
            width: 4px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--gold);
            border-radius: 50px;
        }

        /* ============================================================
           BUILDINGS PAGE
           ============================================================ */
        .buildings-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 16px;
            margin-top: 10px;
        }

        .building-card {
            background: var(--surface);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius);
            padding: 24px;
            box-shadow: var(--shadow);
            transition: var(--transition);
            text-align: center;
        }

        .building-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-hover);
        }

        .building-card .name {
            font-size: 22px;
            font-weight: 900;
            color: var(--gold);
        }

        .building-card .count {
            font-size: 36px;
            font-weight: 900;
            color: var(--text);
            margin: 8px 0;
        }

        .building-card .label {
            color: var(--text-light);
            font-size: 13px;
        }

        /* ============================================================
           RECEIPTS PAGE
           ============================================================ */
        .receipts-list .receipt-item {
            display: flex;
            justify-content: space-between;
            padding: 12px 16px;
            border-bottom: 1px solid var(--glass-border);
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
            background: var(--surface);
            backdrop-filter: blur(24px);
            border-radius: var(--radius-sm);
            margin-bottom: 6px;
            transition: var(--transition);
        }

        .receipts-list .receipt-item:hover {
            background: var(--gold-light);
        }

        .receipts-list .receipt-item .receipt-no {
            font-weight: 800;
            color: var(--gold);
        }

        .receipts-list .receipt-item .receipt-tenant {
            font-weight: 700;
        }

        .receipts-list .receipt-item .receipt-amount {
            font-weight: 800;
            color: var(--gold-dark);
        }

        /* ============================================================
           REPORTS PAGE
           ============================================================ */
        .report-card {
            background: var(--surface);
            backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius);
            padding: 16px 20px;
            margin-bottom: 10px;
            box-shadow: var(--shadow);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
            transition: var(--transition);
        }

        .report-card:hover {
            transform: translateX(-4px);
        }

        .report-card .label {
            font-weight: 700;
            color: var(--text);
        }

        .report-card .value {
            font-weight: 900;
            font-size: 18px;
            color: var(--gold);
        }

        /* ============================================================
           SETTINGS PAGE
           ============================================================ */
        .settings-group {
            background: var(--surface);
            backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius);
            padding: 16px 20px;
            margin-bottom: 12px;
            box-shadow: var(--shadow);
        }

        .settings-group .setting-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid var(--glass-border);
            flex-wrap: wrap;
            gap: 8px;
        }

        .settings-group .setting-item:last-child {
            border-bottom: none;
        }

        .settings-group .setting-item .label {
            font-weight: 700;
            color: var(--text);
        }

        .settings-group .setting-item .control {
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
        }

        .settings-group .setting-item .control button {
            padding: 6px 16px;
            border: none;
            border-radius: 50px;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Tajawal', sans-serif;
            transition: var(--transition);
        }

        .settings-group .setting-item .control button:hover {
            transform: scale(1.05);
        }

        .settings-group .setting-item .control .on {
            background: var(--success);
            color: white;
        }
        .settings-group .setting-item .control .off {
            background: var(--danger);
            color: white;
        }
        .settings-group .setting-item .control .reset-btn {
            background: var(--warning);
            color: white;
        }
        .settings-group .setting-item .control .reset-btn:hover {
            background: #e65100;
        }

        /* ============================================================
           RESPONSIVE - موبائل کے لیے مکمل
           ============================================================ */
        @media (max-width: 768px) {
            .sidebar {
                width: 56px;
                padding: 10px 4px;
            }
            .sidebar .brand h1 {
                font-size: 10px;
            }
            .sidebar .brand .sub {
                display: none;
            }
            .sidebar .menu li a span {
                display: none;
            }
            .sidebar .menu li a .badge {
                display: none;
            }
            .sidebar .menu li a {
                justify-content: center;
                padding: 8px;
            }
            .sidebar .menu li a .icon {
                font-size: 18px;
                width: auto;
            }
            .sidebar .user-info {
                display: none;
            }
            .main-content {
                margin-right: 56px;
                padding: 10px;
            }
            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }
            .rent-item {
                grid-template-columns: 1fr 1fr;
                gap: 4px;
                padding: 12px;
            }
            .rent-item .actions {
                grid-column: span 2;
                display: flex;
                justify-content: center;
                gap: 4px;
            }
            .rent-item .actions button {
                flex: 1;
                text-align: center;
                font-size: 9px;
                padding: 4px 8px;
            }
            .topbar {
                flex-direction: column;
                align-items: stretch;
                text-align: center;
            }
            .topbar-actions {
                justify-content: center;
            }
            .action-bar .btn {
                font-size: 12px;
                padding: 8px 12px;
                min-width: 60px;
            }
            .search-bar input {
                font-size: 13px;
                padding: 8px 12px;
            }
            .search-bar button {
                font-size: 12px;
                padding: 8px 14px;
            }
            .filter-bar button {
                font-size: 10px;
                padding: 4px 10px;
            }
            .modal-content {
                padding: 16px 14px;
            }
            .topbar .page-title {
                font-size: 18px;
            }
            .stat-card .num {
                font-size: 22px;
            }
            .stat-card {
                padding: 12px 8px;
            }
            .buildings-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @media (max-width: 450px) {
            .sidebar {
                width: 44px;
                padding: 6px 2px;
            }
            .main-content {
                margin-right: 44px;
                padding: 6px;
            }
            .stats-grid {
                grid-template-columns: 1fr 1fr;
                gap: 6px;
            }
            .stat-card {
                padding: 8px 4px;
            }
            .stat-card .num {
                font-size: 18px;
            }
            .stat-card .label {
                font-size: 9px;
            }
            .rent-item .info .name {
                font-size: 12px;
            }
            .rent-item .amount {
                font-size: 13px;
            }
            .rent-item .days-left {
                font-size: 10px;
                padding: 2px 8px;
            }
            .rent-item .status {
                font-size: 9px;
                padding: 2px 8px;
            }
            .rent-item .info .unit {
                font-size: 10px;
            }
            .rent-item {
                padding: 10px;
                gap: 3px;
            }
            .action-bar .btn {
                font-size: 10px;
                padding: 6px 10px;
                min-width: 50px;
            }
            .filter-bar button {
                font-size: 9px;
                padding: 3px 8px;
            }
            .topbar .page-title {
                font-size: 16px;
            }
            .topbar-actions button {
                font-size: 11px;
                padding: 4px 10px;
            }
            .search-bar input {
                font-size: 12px;
                padding: 6px 10px;
            }
            .search-bar button {
                font-size: 11px;
                padding: 6px 12px;
            }
            .modal-content {
                padding: 14px 10px;
            }
            .modal-content h2 {
                font-size: 18px;
            }
            .buildings-grid {
                grid-template-columns: 1fr;
            }
        }

        /* ============================================================
           PRINT STYLES
           ============================================================ */
        @media print {
            .sidebar,
            .topbar-actions,
            .search-bar,
            .action-bar,
            .filter-bar,
            .no-print {
                display: none !important;
            }
            .main-content {
                margin-right: 0 !important;
                padding: 10px !important;
            }
            .rent-item {
                break-inside: avoid;
            }
        }
    </style>
</head>
<body>

    <!-- ============================================================
    SIDEBAR - ایڈمن پینل
    ============================================================ -->
    <div class="sidebar">
        <div class="brand">
            <h1>🏢 دروز<br>للعقارية</h1>
            <div class="sub">Druze Real Estate</div>
        </div>
        <ul class="menu">
            <li><a class="active" data-page="dashboard"><span class="icon">📊</span><span>لوحة التحكم</span></a></li>
            <li><a data-page="rents"><span class="icon">📋</span><span>الإيجارات</span><span class="badge" id="rentBadge">0</span></a></li>
            <li><a data-page="buildings"><span class="icon">🏢</span><span>المخارج</span></a></li>
            <li><a data-page="receipts"><span class="icon">🧾</span><span>الإيصالات</span></a></li>
            <li><a data-page="reports"><span class="icon">📈</span><span>التقارير</span></a></li>
            <li><a data-page="settings"><span class="icon">⚙️</span><span>الإعدادات</span></a></li>
        </ul>
        <div class="user-info">
            <div class="name">👤 المدير</div>
            <div class="role">مدير النظام</div>
        </div>
    </div>

    <!-- ============================================================
    MAIN CONTENT
    ============================================================ -->
    <div class="main-content">

        <!-- ===== TOPBAR ===== -->
        <div class="topbar">
            <div class="page-title" id="pageTitle">📊 لوحة <span class="gold">التحكم</span></div>
            <div class="topbar-actions">
                <button class="theme-toggle" id="themeToggle" onclick="toggleTheme()">🌙</button>
                <button onclick="setLang('ar')" id="langAr" class="active">🇸🇦 ع</button>
                <button onclick="setLang('en')" id="langEn">🇬🇧 E</button>
                <button onclick="exportCSV()" class="no-print">📤 تصدير</button>
            </div>
        </div>

        <!-- ============================================================
        PAGE: DASHBOARD
        ============================================================ -->
        <div class="page-section active" id="page-dashboard">

            <!-- STATS -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="num" id="totalPlates">0</div>
                    <div class="label" id="lblTotal">إجمالي الوحدات</div>
                </div>
                <div class="stat-card green">
                    <div class="num" id="totalRent">0</div>
                    <div class="label" id="lblTotalRent">إجمالي الإيجار</div>
                </div>
                <div class="stat-card red">
                    <div class="num" id="overdueCount">0</div>
                    <div class="label" id="lblOverdue">وحدات متأخرة</div>
                </div>
                <div class="stat-card warning">
                    <div class="num" id="upcomingCount">0</div>
                    <div class="label" id="lblUpcoming">مستحق خلال 15 يوم</div>
                </div>
            </div>

            <!-- NOTIFICATION -->
            <div class="notification-banner" id="notifBanner">
                🔔 <span id="notifText">لديك إيجارات مستحقة خلال 15 يومًا</span>
            </div>

            <!-- SEARCH -->
            <div class="search-bar no-print">
                <input type="text" id="searchInput" placeholder="🔍 ابحث عن مستأجر، شقه، أو رقم..." oninput="filterSearch()">
                <button onclick="filterSearch()">🔍 بحث</button>
                <button class="clear-btn" onclick="clearSearch()">✖</button>
            </div>

            <!-- ACTION BAR -->
            <div class="action-bar no-print">
                <button class="btn btn-primary" id="addBtn">➕ <span id="btnAdd">إضافة إيجار</span></button>
                <button class="btn btn-outline" onclick="exportCSV()">📤 <span id="btnExport">تصدير CSV</span></button>
                <button class="btn btn-danger" onclick="confirmDeleteAll()">🗑️ <span id="btnDeleteAll">حذف الكل</span></button>
            </div>

            <!-- FILTERS -->
            <div class="filter-bar no-print">
                <button class="active" data-filter="all" id="fAll">📋 الكل</button>
                <button data-filter="مخرج 25" id="f25">🏢 مخرج 25</button>
                <button data-filter="مخرج 28" id="f28">🏢 مخرج 28</button>
                <button data-filter="unpaid" id="fUnpaid">⏳ متأخر</button>
                <button data-filter="paid" id="fPaid">✅ مدفوع</button>
                <button data-filter="upcoming" id="fUpcoming">🔔 مستحق</button>
            </div>

            <!-- RENT LIST -->
            <div class="rent-list" id="rentList">
                <div class="empty-state">
                    <div class="icon">📋</div>
                    <h3 id="emptyTitle">لا توجد سجلات</h3>
                    <p id="emptyDesc">أضف أول إيجار الآن بالضغط على زر "إضافة إيجار"</p>
                </div>
            </div>
        </div>

        <!-- ============================================================
        PAGE: BUILDINGS
        ============================================================ -->
        <div class="page-section" id="page-buildings">
            <div class="page-header">🏢 المخارج</div>
            <div class="buildings-grid" id="buildingsGrid">
                <div class="building-card">
                    <div class="name">مخرج 25</div>
                    <div class="count" id="b25Count">0</div>
                    <div class="label">وحدة</div>
                </div>
                <div class="building-card">
                    <div class="name">مخرج 28</div>
                    <div class="count" id="b28Count">0</div>
                    <div class="label">وحدة</div>
                </div>
            </div>
        </div>

        <!-- ============================================================
        PAGE: RECEIPTS
        ============================================================ -->
        <div class="page-section" id="page-receipts">
            <div class="page-header">🧾 الإيصالات</div>
            <div class="receipts-list" id="receiptsList">
                <div class="empty-state">
                    <div class="icon">🧾</div>
                    <h3>لا توجد إيصالات</h3>
                    <p>سيتم عرض الإيصالات هنا بعد تسجيل الدفعات</p>
                </div>
            </div>
        </div>

        <!-- ============================================================
        PAGE: REPORTS
        ============================================================ -->
        <div class="page-section" id="page-reports">
            <div class="page-header">📈 التقارير</div>
            <div id="reportsContainer">
                <div class="report-card">
                    <span class="label">📊 إجمالي الإيجار الشهري</span>
                    <span class="value" id="reportTotalRent">0 ريال</span>
                </div>
                <div class="report-card">
                    <span class="label">⏳ إجمالي المتأخرات</span>
                    <span class="value" id="reportOverdue">0 ريال</span>
                </div>
                <div class="report-card">
                    <span class="label">✅ إجمالي المدفوعات</span>
                    <span class="value" id="reportPaid">0 ريال</span>
                </div>
                <div class="report-card">
                    <span class="label">📅 عدد الوحدات النشطة</span>
                    <span class="value" id="reportActive">0</span>
                </div>
            </div>
        </div>

        <!-- ============================================================
        PAGE: SETTINGS
        ============================================================ -->
        <div class="page-section" id="page-settings">
            <div class="page-header">⚙️ الإعدادات</div>
            <div class="settings-group">
                <div class="setting-item">
                    <span class="label">🌙 الوضع الليلي</span>
                    <div class="control">
                        <button onclick="toggleTheme()" id="themeToggleBtn">🌙 تفعيل</button>
                    </div>
                </div>
                <div class="setting-item">
                    <span class="label">🌐 اللغة</span>
                    <div class="control">
                        <button onclick="setLang('ar')" class="on">🇸🇦 العربية</button>
                        <button onclick="setLang('en')" class="off">🇬🇧 English</button>
                    </div>
                </div>
                <div class="setting-item">
                    <span class="label">🗑️ حذف جميع البيانات</span>
                    <div class="control">
                        <button class="reset-btn" onclick="confirmDeleteAll()">🗑️ حذف الكل</button>
                    </div>
                </div>
                <div class="setting-item">
                    <span class="label">📤 تصدير البيانات</span>
                    <div class="control">
                        <button class="on" onclick="exportCSV()">📤 تصدير CSV</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== FOOTER ===== -->
        <div class="footer" id="footerText">© 2026 دروز للعقارية · جميع الحقوق محفوظة</div>
    </div>

    <!-- ============================================================
    MODALS
    ============================================================ -->

    <!-- ADD/EDIT MODAL -->
    <div class="modal" id="addModal">
        <div class="modal-content">
            <h2 id="modalTitle">➕ إضافة <span class="gold">إيجار</span> جديد</h2>

            <label id="lblBuilding">🏢 المخرج</label>
            <select id="buildingSelect">
                <option value="مخرج 25">مخرج 25</option>
                <option value="مخرج 28">مخرج 28</option>
            </select>

            <label id="lblUnit">🔢 شقه نمبر</label>
            <input type="number" id="unitInput" placeholder="مثال: 5" min="1">

            <label id="lblAmount">💰 رقم (ريال)</label>
            <input type="number" id="amountInput" placeholder="مثال: 5000" min="1">

            <label id="lblTenant">👤 اسم المستأجر</label>
            <input type="text" id="tenantInput" placeholder="مثال: أحمد محمد">

            <label id="lblStartDate">📅 تاريخ البدء</label>
            <input type="date" id="startDateInput">

            <label id="lblEndDate">📅 تاريخ الانتهاء</label>
            <input type="date" id="endDateInput">

            <div class="modal-actions">
                <button class="cancel-btn" id="cancelModalBtn">❌ <span id="btnCancel">إلغاء</span></button>
                <button class="save-btn" id="saveRentBtn">💾 <span id="btnSave">حفظ</span></button>
            </div>
        </div>
    </div>

    <!-- DETAIL MODAL -->
    <div class="modal" id="detailModal">
        <div class="modal-content">
            <h2 id="detailTitle">📋 <span class="gold">تفاصيل</span> المستأجر</h2>
            <div id="detailBody"></div>
            <div class="modal-actions">
                <button class="cancel-btn" id="closeDetailBtn">🔙 <span id="btnClose">إغلاق</span></button>
                <button class="danger-btn" id="deleteRentBtn">🗑️ <span id="btnDelete">حذف</span></button>
                <button class="save-btn" id="receiptFromDetailBtn">🧾 <span id="btnReceipt">إيصال</span></button>
            </div>
        </div>
    </div>

    <!-- RECEIPT MODAL -->
    <div class="modal" id="receiptModal">
        <div class="modal-content" style="max-width:480px;">
            <h2>🧾 <span class="gold">إيصال الدفع</span></h2>
            <div id="receiptBody"></div>
