        // BUILDINGS PAGE
        // ============================================================
        function updateBuildings() {
            const b25 = rents.filter(r => r.building === 'مخرج 25').length;
            const b28 = rents.filter(r => r.building === 'مخرج 28').length;
            document.getElementById('b25Count').textContent = b25;
            document.getElementById('b28Count').textContent = b28;
        }

        // ============================================================
        // REPORTS PAGE
        // ============================================================
        function updateReports() {
            const total = rents.reduce((sum, r) => sum + Number(r.amount), 0);
            const overdue = rents.filter(r => !r.paid && new Date(r.endDate) < new Date())
                .reduce((sum, r) => sum + Number(r.amount), 0);
            const paid = rents.filter(r => r.paid).reduce((sum, r) => sum + Number(r.amount), 0);
            const active = rents.filter(r => !r.paid && new Date(r.endDate) >= new Date()).length;

            document.getElementById('reportTotalRent').textContent = total.toLocaleString() + ' ريال';
            document.getElementById('reportOverdue').textContent = overdue.toLocaleString() + ' ريال';
            document.getElementById('reportPaid').textContent = paid.toLocaleString() + ' ريال';
            document.getElementById('reportActive').textContent = active;
        }

        // ============================================================
        // RECEIPTS PAGE
        // ============================================================
        function updateReceipts() {
            const container = document.getElementById('receiptsList');
            const paidRents = rents.filter(r => r.paid);

            if (paidRents.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <div class="icon">🧾</div>
                        <h3>${currentLang === 'ar' ? 'لا توجد إيصالات' : 'No Receipts'}</h3>
                        <p>${currentLang === 'ar' ? 'سيتم عرض الإيصالات هنا بعد تسجيل الدفعات' : 'Receipts will appear here after payments are recorded'}</p>
                    </div>
                `;
                return;
            }

            let html = '';
            paidRents.forEach((r, i) => {
                const date = r.paidDate ? new Date(r.paidDate).toLocaleDateString(
                    currentLang === 'ar' ? 'ar-EG' : 'en-US'
                ) : '-';
                html += `
                    <div class="receipt-item">
                        <span class="receipt-no">#${String(i + 1).padStart(4, '0')}</span>
                        <span class="receipt-tenant">${r.tenant}</span>
                        <span>شقه ${r.unit}</span>
                        <span class="receipt-amount">${Number(r.amount).toLocaleString()} ريال</span>
                        <span style="font-size:12px;color:var(--text-light);">${date}</span>
                        <button onclick="showReceipt(${r.id})" style="background:var(--gold);border:none;padding:4px 14px;border-radius:50px;cursor:pointer;font-weight:700;color:white;font-family:'Tajawal',sans-serif;transition:var(--transition);">🧾 عرض</button>
                    </div>
                `;
            });
            container.innerHTML = html;
        }

        // ============================================================
        // RENDER - مرکزی لسٹ
        // ============================================================
        function render() {
            const list = document.getElementById('rentList');
            let filtered = [...rents];

            if (searchQuery.trim()) {
                const q = searchQuery.trim().toLowerCase();
                filtered = filtered.filter(r =>
                    r.tenant.toLowerCase().includes(q) ||
                    String(r.unit).includes(q) ||
                    String(r.amount).includes(q) ||
                    r.building.includes(q)
                );
            }

            if (currentFilter === 'paid') filtered = filtered.filter(r => r.paid === true);
            else if (currentFilter === 'unpaid') filtered = filtered.filter(r => r.paid === false);
            else if (currentFilter === 'upcoming') {
                const today = new Date();
                today.setHours(0, 0, 0, 0);
                filtered = filtered.filter(r => {
                    if (r.paid) return false;
                    const end = new Date(r.endDate);
                    end.setHours(0, 0, 0, 0);
                    const diff = (end - today) / (1000 * 60 * 60 * 24);
                    return diff >= 0 && diff <= 15;
                });
            } else if (currentFilter === 'مخرج 25' || currentFilter === 'مخرج 28') {
                filtered = filtered.filter(r => r.building === currentFilter);
            }

            filtered.sort((a, b) => new Date(a.endDate) - new Date(b.endDate));

            // Stats
            document.getElementById('totalPlates').textContent = rents.length;
            const total = rents.reduce((sum, r) => sum + Number(r.amount), 0);
            document.getElementById('totalRent').textContent = total.toLocaleString();
            const overdue = rents.filter(r => !r.paid && new Date(r.endDate) < new Date()).length;
            document.getElementById('overdueCount').textContent = overdue;

            const today = new Date();
            today.setHours(0, 0, 0, 0);
            const upcoming = rents.filter(r => {
                if (r.paid) return false;
                const end = new Date(r.endDate);
                end.setHours(0, 0, 0, 0);
                const diff = (end - today) / (1000 * 60 * 60 * 24);
                return diff >= 0 && diff <= 15;
            });
            document.getElementById('upcomingCount').textContent = upcoming.length;

            if (filtered.length === 0) {
                list.innerHTML = `
                    <div class="empty-state">
                        <div class="icon">📋</div>
                        <h3>${t('emptyTitle')}</h3>
                        <p>${t('emptyDesc')}</p>
                    </div>
                `;
                return;
            }

            let html = '';
            const now = new Date();
            now.setHours(0, 0, 0, 0);

            filtered.forEach((rent) => {
                const isPaid = rent.paid === true;
                const end = new Date(rent.endDate);
                end.setHours(0, 0, 0, 0);
                const diffDays = Math.ceil((end - now) / (1000 * 60 * 60 * 24));
                const isOverdue = !isPaid && end < now;
                const isWarning = !isPaid && diffDays >= 0 && diffDays <= 15;

                let statusClass = 'unpaid';
                let statusText = t('unpaidStatus');
                if (isPaid) { statusClass = 'paid';
                    statusText = t('paidStatus'); } else if (isOverdue) { statusClass = 'unpaid';
                    statusText = t('unpaidStatus'); } else if (isWarning) { statusClass = 'warning';
                    statusText = t('warningStatus'); }

                const startStr = new Date(rent.startDate).toLocaleDateString(
                    currentLang === 'ar' ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' }
                );
                const endStr = new Date(rent.endDate).toLocaleDateString(
                    currentLang === 'ar' ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' }
                );

                const daysLeft = getDaysLeft(rent.endDate);
                const daysText = getDaysLeftText(daysLeft);
                const daysClass = getDaysLeftClass(daysLeft);

                const warningBadge = isWarning ? `<span class="notif-badge">${diffDays} ${t('day')}</span>` : '';

                html += `
                    <div class="rent-item" data-id="${rent.id}">
                        <div class="info">
                            <div class="name">${rent.tenant} ${warningBadge}</div>
                            <div class="unit">🔹 شقه ${rent.unit} · رقم ${Number(rent.amount).toLocaleString()}</div>
                            <div class="small">🏢 ${rent.building} · 📅 ${startStr} → ${endStr}</div>
                        </div>
                        <div class="amount">${Number(rent.amount).toLocaleString()} ريال</div>
                        <div class="days-left ${daysClass}">⏳ ${daysText}</div>
                        <div class="status ${statusClass}">${statusText}</div>
                        <div class="actions">
                            ${!isPaid ? `<button class="pay-btn" data-id="${rent.id}">✅ ${t('payBtn')}</button>` : `<button class="receipt-btn" data-id="${rent.id}">🧾 ${t('receiptBtn')}</button>`}
                            <button class="edit-btn" data-id="${rent.id}">✏️ ${t('editBtn')}</button>
                        </div>
                    </div>
                `;
            });

            list.innerHTML = html;

            document.querySelectorAll('.pay-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    markPaid(this.dataset.id);
                });
            });

            document.querySelectorAll('.edit-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    openEditModal(this.dataset.id);
                });
            });

            document.querySelectorAll('.receipt-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    showReceipt(this.dataset.id);
                });
            });

            document.querySelectorAll('.rent-item').forEach(item => {
                item.addEventListener('click', function() {
                    showDetail(this.dataset.id);
                });
            });
        }

