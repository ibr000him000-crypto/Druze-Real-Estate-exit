            );
            const paidStr = rent.paidDate ? new Date(rent.paidDate).toLocaleDateString(
                currentLang === 'ar' ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' }
            ) : '-';
            const statusText = rent.paid ? t('paidStatus') : t('unpaidStatus');

            document.getElementById('receiptBody').innerHTML = `
                <div class="receipt" id="receiptContent">
                    <div class="header">
                        <h2>🏢 دروز للعقارية</h2>
                        <div class="sub">Druze Real Estate</div>
