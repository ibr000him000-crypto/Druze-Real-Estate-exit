                <button class="print-btn" onclick="printReceipt()">🖨️ طباعة</button>
                <button class="close-btn" id="closeReceiptBtn">✖ إغلاق</button>
            </div>
        </div>
    </div>

    <!-- TOAST -->
    <div class="toast-container" id="toastContainer"></div>

